---
import { requireAdmin } from '@/lib/auth';
import { db, schema } from '@/db';
import { ensureUniqueSlug } from '@/lib/slug';

export const prerender = false;

const denied = requireAdmin(Astro, 'page');
if (denied) return denied;

// Create a blank draft and redirect into the editor
const slug = await ensureUniqueSlug('untitled');
const [row] = await db
  .insert(schema.posts)
  .values({
    title: 'Untitled',
    slug,
    contentMd: '',
    contentHtml: '',
  })
  .returning();

return Astro.redirect(`/admin/edit/${row!.id}`);
---
