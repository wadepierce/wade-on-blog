# Postgres connection string (Railway's Postgres plugin injects this automatically)
DATABASE_URL=postgres://user:password@localhost:5432/wade_on_blog

# WebAuthn relying party
# RP_ID must be a bare hostname (no scheme, no port) and must match RP_ORIGIN's host
RP_ID=localhost
RP_ORIGIN=http://localhost:4321

# Where uploaded images are written.
# On Railway, mount a volume at /data and set this to /data/uploads.
UPLOADS_DIR=./.uploads

# Port the Node server listens on (Railway injects PORT automatically)
PORT=4321
HOST=0.0.0.0
